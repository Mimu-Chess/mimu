{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mimu Chess",
  "version": "1.0.0",
  "identifier": "com.mimuchess.desktop",
  "build": {
    "beforeDevCommand": "npm run tauri:stack",
    "beforeBuildCommand": "npm run tauri:prep",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mimu Chess",
        "width": 1480,
        "height": 940,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "resources": [
      "../../server/dist/**/*",
      "../../server/node_modules/**/*",
      "../../server/package.json"
    ],
    "externalBin": [
      "bin/node"
    ]
  }
}

